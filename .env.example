# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local for local dev:   cp .env.example .env.local
# On Vercel, add these same keys under Project → Settings → Environment Variables
# (do NOT commit real secrets — .env.local is gitignored).
# ─────────────────────────────────────────────────────────────

# ── Hostinger SMTP ─────────────────────────────────────────────
# Find these in hPanel → Emails → your mailbox → "Connect Devices"

# Usually smtp.hostinger.com
SMTP_HOST=smtp.hostinger.com

# 465 = SSL (recommended) | 587 = STARTTLS
SMTP_PORT=465

# true for port 465, false for port 587
SMTP_SECURE=true

# Your full Hostinger email address (also the SMTP username)
SMTP_USER=you@yourdomain.com

# Your Hostinger mailbox password
SMTP_PASS=your-mailbox-password

# ── Mail content ───────────────────────────────────────────────

# What recipients see in the "From" field.
# The email part MUST match SMTP_USER or Hostinger will reject it.
MAIL_FROM=Your Company <you@yourdomain.com>

# Where YOU receive a notification for each signup. Leave blank to disable.
NOTIFY_TO=you@yourdomain.com

# Friendly name used inside the email subject/body.
COMPANY_NAME=Your Company

# ── Bundle download links (buttons in the contact's delivery email) ──
# Presentation decks (English & Spanish, 4 files) — e.g. a Dropbox folder link.
PRESENTATIONS_URL=
# Crypto Workflow Toolkit ZIP. Leave BLANK to serve /public/<zip> automatically;
# set only to override with an external/CDN link.
WORKFLOW_ZIP_URL=
